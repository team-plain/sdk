{
  "name": "@team-plain/webhooks",
  "version": "1.1.0",
  "description": "Webhook parsing and signature verification for Plain webhooks",
  "license": "MIT",
  "author": "Plain <hello@plain.com> (https://plain.com)",
  "homepage": "https://github.com/team-plain/sdk/tree/main/packages/webhooks#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/team-plain/sdk.git",
    "directory": "packages/webhooks"
  },
  "bugs": {
    "url": "https://github.com/team-plain/sdk/issues"
  },
  "keywords": [
    "plain",
    "webhooks",
    "signature-verification",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsup",
    "test": "vitest run",
    "codegen": "sh ./scripts/codegen-webhooks.sh"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "json-schema-to-typescript": "^13.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
