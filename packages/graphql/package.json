{
  "name": "@team-plain/graphql",
  "version": "1.0.1",
  "description": "Typed TypeScript SDK for Plain's GraphQL API with auto-generated model classes",
  "license": "MIT",
  "author": "Plain <hello@plain.com> (https://plain.com)",
  "homepage": "https://github.com/team-plain/sdk/tree/main/packages/graphql#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/team-plain/sdk.git",
    "directory": "packages/graphql"
  },
  "bugs": {
    "url": "https://github.com/team-plain/sdk/issues"
  },
  "keywords": [
    "plain",
    "graphql",
    "sdk",
    "typescript",
    "api",
    "customer-support"
  ],
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate-documents": "tsx src/generate-documents.ts",
    "download-schema": "tsx scripts/download-schema.ts",
    "codegen": "pnpm download-schema && tsx src/generate-documents.ts && graphql-codegen --config codegen.yml",
    "build": "tsc && tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typed-document-node": "^5.0.12",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-operations": "^4.3.2",
    "@team-plain/graphql-codegen-plugin": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
