{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.json",
      "**/*.yml",
      "!!**/dist/",
      "!!**/node_modules/",
      "!!**/_generated_*"
    ]
  }
}
