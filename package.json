{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @team-plain/codegen-plugin build && pnpm --filter @team-plain/sdk codegen && pnpm --filter @team-plain/sdk build",
    "typecheck": "tsc --noEmit --project packages/codegen-plugin/tsconfig.json && tsc --noEmit --project packages/sdk/tsconfig.json",
    "test": "pnpm --filter @team-plain/codegen-plugin test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/cli": "^2.30.0",
    "graphql": "^16.13.1",
    "vitest": "^4.1.0"
  }
}